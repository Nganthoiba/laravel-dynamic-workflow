{
    "name": "nganthoiba/laravel-dynamic-workflow",
    "description": "A dynamic graph-based workflow engine and visual designer for Laravel.",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Workflow\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Workflow\\Providers\\WorkflowServiceProvider"
            ]
        }
    }
}
