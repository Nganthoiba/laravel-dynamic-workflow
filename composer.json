{
    "name": "nganthoiba/laravel-dynamic-workflow",
    "description": "A dynamic graph-based workflow engine and visual designer for Laravel.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "illuminate/view": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Workflow\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Workflow\\Providers\\WorkflowServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7"
    }
}
